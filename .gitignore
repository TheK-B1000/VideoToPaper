.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Environment secrets
.env
.env.*
!.env.example

# Local-only overrides (may enable LLM); never commit secrets here
configs/*.local.json

# Keep layout; ignore generated/large files under these trees
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/outputs/*
!data/outputs/.gitkeep

logs/runs/*
!logs/runs/.gitkeep

logs/budget/*
!logs/budget/.gitkeep
logs/test_runs/

reports/
.tmp/

.DS_Store
Thumbs.db
